function uploadPuxFile(zip, filename, id, binaryAesKey, safeID) {

    return zip.file(filename).async("arraybuffer").then(pFileContent => {
        const { fileInfo, cFileContent } = passhubCrypto.encryptFile(
            pFileContent,
            binaryAesKey
        );

        const data = new FormData();
        data.append("vault", safeID);
        data.append("verifier", getVerifier());

        data.append("puxId", id);
        data.append("fileInfo", fileInfo);
        const ab = passhubCrypto.str2uint8(cFileContent);
        const bl = new Blob([ab]);
        data.append("blob", bl);

        return axios
            .post(`${getApiUrl()}upload_pux_file.php`, data, {
                headers: {
                    "content-type": "multipart/form-data",
                },
                timeout: 600000,
            })
            .then(response => {
                const result = response.data;

                if (result.status === "Ok") {
                    if (result.firstID) {
                        props.newItemInd(result.firstID);
                    }
                    return result;
                }
                if (response.status === "login") {
                    window.location.href = "expired.php";
                    return;
                }
                throw new Error(result.status);
            })
    })
}

async function uploadFiles(zip, filesToUpload, binaryKey, safeID) {
    for (const { filename, id } of filesToUpload) {
        await uploadPuxFile(zip, filename, id, binaryKey, safeID);
    }
    return "1PUX files uploaded";
}

async function import1PUX(zipFileContent, puxFilename) {

    fileIDs = [];
    let aesKey;
    const zip = new JSZip();

    return zip.loadAsync(zipFileContent)
        .then(() => zip.file("export.data").async("string"))
        .then(jsonObj => {
            const obj = JSON.parse(jsonObj);
            return onePassToPasshub(obj, puxFilename).then(imported => {
                const filesToUpload = []
                zip.folder("files").forEach((relativePath, file) => {
                    for (const fid of fileIDs) {
                        if (file.name.includes(fid)) {
                            filesToUpload.push({ filename: file.name, id: fid })
                            continue;
                        }
                    }
                })

                const { safe: importedSafe, binaryKey } = passhubCrypto.createSafeFromFolder(imported, true)
                aesKey = binaryKey;
                return uploadImportedData([importedSafe]).then((r) => {
                    if ((r.status == "Ok") && (r.safeIDs.length == 1)) {
                        const safeID = r.safeIDs[0];
                        return uploadFiles(zip, filesToUpload, binaryKey, safeID);
                    }
                    return r;
                })
            })
        })
        .catch(err => {
            console.log('error 280')
            console.log(err)
        });
}

export default import1PUX;

let fileIDs = [];


function getTags(item) {
    let tags = '';

    if (("tags" in item.overview) && (Array.isArray(item.overview.tags))) {
        tags += '\n\ntags: ';
        tags += item.overview.tags.join(' ');
        tags += '\n';
    }
    return tags;
}


function unknownToPasshub(item) {
    const title = ("title" in item.overview) ? item.overview.title : "unnamed";

    let note = `1Password record type ${item.categoryUuid}\n\n`;

    if (item.categoryUuid == "004") {
        note = "1Password record type IDENTITY\n\n";
    }
    if (item.categoryUuid == "100") {
        note = "1Password record type SOFTWARE LICENSE\n\n";
    }
    if (item.categoryUuid == "101") {
        note = "1Password record type BANK ACCOUNT\n\n";
    }
    if (item.categoryUuid == "102") {
        note = "1Password record type DATABASE\n\n";
    }
    if (item.categoryUuid == "103") {
        note = "1Password record type DRIVER LICENSE\n\n";
    }
    if (item.categoryUuid == "104") {
        note = "1Password record type OUTDOOR LICENSE\n\n";
    }
    if (item.categoryUuid == "105") {
        note = "1Password record type MEMBERSHIP\n\n";
    }
    if (item.categoryUuid == "106") {
        note = "1Password record type PASSPORT\n\n";
    }
    if (item.categoryUuid == "107") {
        note = "1Password record type REWARDS\n\n";
    }
    if (item.categoryUuid == "109") {
        note = "1Password record type WIRELESS ROUTER\n\n";
    }
    if (item.categoryUuid == "110") {
        note = "1Password record type SERVER\n\n";
    }
    if (item.categoryUuid == "111") {
        note = "1Password record type EMAIL\n\n";
    }
    if (item.categoryUuid == "112") {
        note = "1Password record type API CREDENTIALS\n\n";
    }
    if (item.categoryUuid == "113") {
        note = "1Password record type MEDICAL RECORD\n\n";
    }
    if (item.categoryUuid == "114") {
        note = "1Password record type SSH KEY\n\n";
    }
    if (item.categoryUuid == "115") {
        note = "1Password record type CRYPTO WALLET\n\n";
    }

    if (("sections" in item.details)
        && Array.isArray(item.details.sections)
        && (item.details.sections.length > 0)
        && ("fields" in item.details.sections[0])
        && Array.isArray(item.details.sections[0].fields)) {

        for (const field of item.details.sections[0].fields) {
            let value = [];
            for (const v in field.value) {
                value.push(field.value[v])
            }

            note += `${field.title}: ${value.join(' ')}\n`
        }
    }

    note += "\n";

    note += ("notesPlain" in item.details) ? item.details.notesPlain : '';
    note += getTags(item);

    return { cleartext: [title, '', '', '', note], options: { note: 1 } }
}


function fileToPasshub(item) {
    let title = ("title" in item.overview) ? item.overview.title : "unnamed";

    if ("documentAttributes" in item.details) {
        for (const key in item.details.documentAttributes) {
            if (key == "documentId") {
                fileIDs.push(item.details.documentAttributes[key]);
            }
            if (key == "fileName") {
                title = item.details.documentAttributes[key];
            }
        }
    }

    let note = ("notesPlain" in item.details) ? item.details.notesPlain : '';
    note += getTags(item);

    return { cleartext: [title, '', '', '', note], options: { note: 1, onePasswordDocumentId: item.details.documentAttributes.documentId } }
}

function noteToPasshub(item) {
    const title = ("title" in item.overview) ? item.overview.title : "unnamed";
    let note = ("notesPlain" in item.details) ? item.details.notesPlain : '';
    note += getTags(item);

    return { cleartext: [title, '', '', '', note], options: { note: 1 } }
}

function loginToPasshub(item) {
    const title = ("title" in item.overview) ? item.overview.title : "unnamed";
    let username = '';
    let password = '';
    let urls = [];

    try {
        for (const field of item.details.loginFields) {
            if (field.designation == "username") {
                username = field.value;
            }
            if (field.designation == "password") {
                password = field.value;
            }
        }
        if ('urls' in item.overview) {
            for (const url of item.overview.urls) {
                urls.push(url.url)
            }
        }
    } catch (err) {
        console.log(err);
    }

    let note = ("notesPlain" in item.details) ? item.details.notesPlain : '';
    note += getTags(item);


    if (("sections" in item.details)
        && Array.isArray(item.details.sections)
        && (item.details.sections.length > 0)
        && ("fields" in item.details.sections[0])
        && Array.isArray(item.details.sections[0].fields)) {

        let totp;
        for (const field of item.details.sections[0].fields) {
            if (field?.title == "one-time password")
                totp = field?.value?.totp;
        }

        if (totp) {
            return { cleartext: [title, username, password, urls.join('\x01'), note, totp] }
        }
    }

    return { cleartext: [title, username, password, urls.join('\x01'), note] }
}



function sshToPasshub(item) {

    const title = ("title" in item.overview) ? item.overview.title : "unnamed";

    let sshKey = {};

    try {
        for (const field of item.details.sections[0].fields) {
            if (field.id == "private_key") {
                sshKey = field.value.sshKey;
            }
        }
    } catch (err) {
        console.log(err);
    }

    let note = JSON.stringify(sshKey);
    note += '\n';
    note += ("notesPlain" in item.details) ? item.details.notesPlain : '';
    note += getTags(item);
    return { cleartext: [title, '', '', '', note], options: { note: 1 } }
}

function cardToPasshub(item) {

    const title = ("title" in item.overview) ? item.overview.title : "unnamed";

    let ccNumber = '';
    let ccName = '';
    let ccExpMonth = '';
    let ccExpYear = '';
    let ccCSC = '';


    try {
        for (const field of item.details.sections[0].fields) {
            if (field.id == "cardholder") {
                ccName = field.value.string;
            }
            if (field.id == "ccnum") {
                ccNumber = field.value.creditCardNumber;
            }
            if (field.id == "cvv") {
                ccCSC = field.value.concealed;
            }
            if (field.id == "expiry") {
                let expiry = field.value.monthYear;
                if ((typeof expiry) == "number") {
                    expiry = expiry.toString();
                }
                if ((expiry.length == 6) && (expiry.substring(0, 1) == '2')) {

                    ccExpYear = expiry.substring(0, 4);
                    ccExpMonth = expiry.substring(4, 6);
                }
            }
        }
    } catch (err) {
        console.log(err);
    }

    let note = ("notesPlain" in item.details) ? item.details.notesPlain : '';
    note += getTags(item);

    return { cleartext: ["card", title, note, ccNumber, ccName, ccExpMonth, ccExpYear, ccCSC], options: { version: 5 } }

}

function toPasshub(item) {
    let result = [];
    if ("categoryUuid" in item) {

        if (item.categoryUuid == "001") {
            return loginToPasshub(item);
        }
        if (item.categoryUuid == "002") {
            return cardToPasshub(item);
        }
        if (item.categoryUuid == "003") {
            return noteToPasshub(item);
        }

        if (item.categoryUuid == "006") {
            return fileToPasshub(item);
        }

        if (item.categoryUuid == "114") {
            return sshToPasshub(item);
        }

        return unknownToPasshub(item);
    }
    return result;
}

async function onePassToPasshub(onePass, fileName) {
    let result = {
        name: fileName,
        folders: [],
        items: []
    };
    if (("accounts" in onePass)
        && Array.isArray(onePass.accounts)
        && (onePass.accounts.length > 0)
        && ("vaults" in onePass.accounts[0])
        && Array.isArray(onePass.accounts[0].vaults)
    ) {

        const vaults = onePass.accounts[0].vaults;
        for (const vault of vaults) {
            const folder = {
                folders: [],
                items: []
            };
            const folderName = ("name" in vault.attrs) ? vault.attrs.name : "unnamed";
            folder.name = folderName;

            if (("items" in vault)
                && Array.isArray(vault.items)
            ) {
                for (const item of vault.items) {
                    const oitem = toPasshub(item);
                    folder.items.push(oitem)
                }
            }
            result.folders.push(folder);
        }
    }
    return result;
}

